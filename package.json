		"test:e2e": "start-server-and-test 'pnpm start' localhost:4321 'playwright test'"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/mdx": "4.3.14",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@astrojs/tailwind": "6.0.2",
		"@astrojs/vercel": "9.0.5",
		"@vercel/analytics": "1.6.1",
		"astro": "5.18.1",
		"astro-expressive-code": "0.42.0",
		"astro-icon": "1.1.5",
		"clsx": "2.1.1",
		"mdast-util-to-string": "4.0.0",
		"reading-time": "1.5.0",
		"rehype-external-links": "3.0.0",
		"remark-unwrap-images": "4.0.1",
		"sharp": "0.34.5",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "3.4.19"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@playwright/test": "1.60.0",
