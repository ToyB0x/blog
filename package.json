{
	"name": "blog",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"dev": "astro check --watch & astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "biome check",
		"check:write": "biome check --write",
		"check:write:unsafe": "biome check --write --unsafe",
